# ─────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — never commit secrets
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Docker / Database volumes
# ─────────────────────────────────────────────────────────────────────────────
postgres_data/
backend/postgres_data/
*.db
*.db-shm
*.db-wal

# ─────────────────────────────────────────────────────────────────────────────
# Build outputs
# ─────────────────────────────────────────────────────────────────────────────
# Next.js
frontend/.next/
frontend/out/
frontend/build/

# Backend compiled JS
backend/dist/
backend/build/

# Prisma generated client (regenerated on install / prisma generate)
backend/node_modules/.prisma/
backend/generated/

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# Testing & coverage
# ─────────────────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─────────────────────────────────────────────────────────────────────────────
# Caches
# ─────────────────────────────────────────────────────────────────────────────
.npm/
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
.turbo/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ─────────────────────────────────────────────────────────────────────────────
# OS / Editor artifacts
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.suo
*.user
.vscode/
!.vscode/extensions.json
.idea/

# ─────────────────────────────────────────────────────────────────────────────
# Deployment
# ─────────────────────────────────────────────────────────────────────────────
.vercel/
.serverless/

# ─────────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────────
*.tgz
*.pid
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
